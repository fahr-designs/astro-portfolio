---
// TODO: Consider if Formspree is the right call for form submission
// To wire up form submission:
//   - SSR mode: create src/pages/api/contact.ts and POST here
//   - Static export: use Formspree (change form action to https://formspree.io/f/YOUR_ID)
const pageTitle = "Contact — Franco";
const email = "franco.aguilar.hr@gmail.com";     // NOTE: replace with your actual email
const location = "Kansas City, KS";
const availability = "Open to opportunities";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- Google Fonts — same as index -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      /* ─── Design tokens — identical to index.astro ─── */
      :root {
        --light-bg:    #f0efec;
        --dark-text:   #1c2b25;
        --green:       #3a7a5a;
        --green-hover: #2e6148;
        --green-faint: rgba(58, 122, 90, 0.08);
        --mauve:       #8b3558;
        --mauve-dark:  #6e2944;
        --mauve-text:  #ffffff;
        --muted:       #6b7b72;
        --border:      #d4d2ce;
        --field-bg:    #ffffff;
        --font:        'Nunito', sans-serif;
      }

      html, body {
        height: 100%;
        font-family: var(--font);
        overflow: hidden;
      }

      /* ─── Split layout — mirrors index.astro ─── */
      .split {
        display: flex;
        height: 100vh;
        width: 100vw;
      }

      .panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 4rem;
      }

      /* ─── Left: form ─── */
      .panel--left {
        background-color: var(--light-bg);
        color: var(--dark-text);
        overflow-y: auto;
      }

      .form-wrap {
        width: 100%;
        max-width: 440px;
      }

      .page-label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 0.5rem;
      }

      h1 {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        font-weight: 900;
        color: var(--dark-text);
        line-height: 1.1;
        margin-bottom: 0.5rem;
      }

      .subtext {
        font-size: 0.88rem;
        font-weight: 400;
        color: var(--muted);
        margin-bottom: 2rem;
        line-height: 1.6;
      }

      /* ─── Fields ─── */
      .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .field--full {
        grid-column: 1 / -1;
      }

      label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }

      input,
      textarea {
        background: var(--field-bg);
        border: 1.5px solid var(--border);
        border-radius: 6px;
        color: var(--dark-text);
        font-family: var(--font);
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.6rem 0.875rem;
        outline: none;
        width: 100%;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
        -webkit-appearance: none;
      }

      input::placeholder,
      textarea::placeholder {
        color: #b5b3ae;
        font-weight: 400;
      }

      input:focus,
      textarea:focus {
        border-color: var(--green);
        box-shadow: 0 0 0 3px var(--green-faint);
      }

      input.invalid,
      textarea.invalid {
        border-color: var(--mauve);
        box-shadow: 0 0 0 3px rgba(139, 53, 88, 0.08);
      }

      textarea {
        resize: vertical;
        min-height: 120px;
      }

      .error {
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--mauve);
        min-height: 1em;
        letter-spacing: 0.02em;
      }

      /* ─── Form footer ─── */
      .form-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1.5px solid var(--border);
      }

      .privacy-note {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--muted);
      }

      .btn-submit {
        background-color: var(--green);
        border: none;
        border-radius: 6px;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        padding: 0.65rem 1.5rem;
        transition: background-color 0.15s ease, transform 0.1s ease;
        white-space: nowrap;
      }

      .btn-submit:hover:not(:disabled) {
        background-color: var(--green-hover);
      }

      .btn-submit:active:not(:disabled) {
        transform: translateY(1px);
      }

      .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .btn-arrow {
        font-size: 1rem;
        transition: transform 0.15s ease;
      }

      .btn-submit:hover:not(:disabled) .btn-arrow {
        transform: translateX(3px);
      }

      #form-status {
        margin-top: 1rem;
        font-size: 0.8rem;
        font-weight: 700;
        min-height: 1.2em;
      }

      .status--success { color: var(--green); }
      .status--error   { color: var(--mauve); }

      /* ─── Right: info panel ─── */
      .panel--right {
        background-color: var(--mauve);
        color: var(--mauve-text);
        position: relative;
      }

      /* dot texture — same as index.astro */
      .panel--right::before {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
        background-size: 22px 22px;
      }

      .right-content {
        position: relative;
        z-index: 1;
        max-width: 320px;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      .right-heading {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        font-weight: 900;
        color: #fff;
        line-height: 1.15;
      }

      .right-heading span {
        display: block;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.55);
        margin-bottom: 0.5rem;
      }

      .contact-details {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }

      .contact-details li {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .detail-label {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
      }

      .detail-value {
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
      }

      .detail-value a {
        color: #fff;
        text-decoration: none;
        border-bottom: 1.5px solid rgba(255,255,255,0.3);
        transition: border-color 0.15s;
      }

      .detail-value a:hover {
        border-color: #fff;
      }

      .availability-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.12);
        border-radius: 100px;
        padding: 0.45rem 1rem;
        font-size: 0.78rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: 0.02em;
        width: fit-content;
      }

      .availability-badge::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #6ee7a0;
        flex-shrink: 0;
      }

      /* ─── Responsive ─── */
      @media (max-width: 768px) {
        html, body { overflow: auto; }

        .split {
          flex-direction: column;
          height: auto;
          min-height: 100vh;
        }

        .panel {
          padding: 3rem 1.5rem;
        }

        .field-row {
          grid-template-columns: 1fr;
        }

        .field--full {
          grid-column: 1;
        }

        .form-footer {
          flex-direction: column;
          align-items: flex-start;
        }

        .btn-submit {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <div class="split">

      <!-- Left: contact form -->
      <div class="panel panel--left">
        <div class="form-wrap">
          <span class="page-label">
            <a href="/"> &#8592; Home</a>
          </span>
          <h1>Let's talk.</h1>
          <p class="subtext">Fill out the form and I'll get back to you within a few days.</p>

          <form id="contact-form" method="POST" action="/api/contact" novalidate>
            <div class="field-row">
              <div class="field">
                <label for="name">Full name</label>
                <input type="text" id="name" name="name" placeholder="Your name" autocomplete="name" required />
                <span class="error" id="name-error"></span>
              </div>
              <div class="field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" autocomplete="email" required />
                <span class="error" id="email-error"></span>
              </div>
              <div class="field field--full">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" placeholder="What's this about?" required />
                <span class="error" id="subject-error"></span>
              </div>
              <div class="field field--full">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5" placeholder="Write your message here..." required></textarea>
                <span class="error" id="message-error"></span>
              </div>
            </div>

            <div class="form-footer">
              <p class="privacy-note">Your info is never shared or sold.</p>
              <button type="submit" class="btn-submit" id="submit-btn">
                <span class="btn-text">Send message</span>
                <span class="btn-arrow">→</span>
              </button>
            </div>

            <div id="form-status" role="alert" aria-live="polite"></div>
          </form>
        </div>
      </div>

      <!-- Right: contact info -->
      <div class="panel panel--right">
        <div class="right-content">
          <div class="right-heading">
            <span>FAHR Designs</span>
            Get in touch — I'd love to hear from you.
          </div>

          <ul class="contact-details">
            <li>
              <span class="detail-label">Email</span>
              <span class="detail-value">
                <a href={`mailto:${email}`}>{email}</a>
              </span>
            </li>
            <li>
              <span class="detail-label">Location</span>
              <span class="detail-value">{location}</span>
            </li>
            <li>
              <span class="detail-label">Status</span>
              <span class="detail-value">
                <span class="availability-badge">{availability}</span>
              </span>
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>

    <script>
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
      const statusEl = document.getElementById("form-status") as HTMLElement;

      const fields = [
        { id: "name",    errorId: "name-error",    message: "Name is required." },
        { id: "email",   errorId: "email-error",   message: "A valid email is required." },
        { id: "subject", errorId: "subject-error", message: "Subject is required." },
        { id: "message", errorId: "message-error", message: "Message is required." },
      ];

      function clearErrors() {
        fields.forEach(({ errorId }) => {
          const el = document.getElementById(errorId);
          if (el) el.textContent = "";
        });
        statusEl.textContent = "";
        statusEl.className = "";
      }

      function validate(): boolean {
        let valid = true;
        fields.forEach(({ id, errorId, message }) => {
          const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
          const error = document.getElementById(errorId);
          if (!input || !error) return;
          const value = input.value.trim();
          if (!value) {
            error.textContent = message;
            input.classList.add("invalid");
            valid = false;
          } else if (id === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
            error.textContent = message;
            input.classList.add("invalid");
            valid = false;
          } else {
            input.classList.remove("invalid");
          }
        });
        return valid;
      }

      fields.forEach(({ id, errorId }) => {
        const input = document.getElementById(id);
        const error = document.getElementById(errorId);
        input?.addEventListener("input", () => {
          if (error) error.textContent = "";
          input.classList.remove("invalid");
        });
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearErrors();
        if (!validate()) return;

        submitBtn.disabled = true;
        submitBtn.querySelector(".btn-text")!.textContent = "Sending...";

        try {
          // Replace with your actual submission logic:
          //   SSR:       fetch(form.action, { method: "POST", body: new FormData(form) })
          //   Formspree: change form action to your Formspree URL
          //   Netlify:   add data-netlify="true" to <form>, remove this handler
          await new Promise((r) => setTimeout(r, 1200));

          form.reset();
          statusEl.textContent = "Message sent. I'll be in touch soon.";
          statusEl.className = "status--success";
        } catch {
          statusEl.textContent = "Something went wrong. Please try again.";
          statusEl.className = "status--error";
        } finally {
          submitBtn.disabled = false;
          submitBtn.querySelector(".btn-text")!.textContent = "Send message";
        }
      });
    </script>
  </body>
</html>