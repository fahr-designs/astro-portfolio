---
// TODO: add a shared nav later, wrap with Layout component and remove the <html>/<head>/<body> tags here.
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const name = "Franco";
const role = "Full Stack Software Developer";
const tagline = "Creator of FAHR Designs.";
const headshot = "/images/playful-headshot.webp";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About — {name}</title>

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- Google Fonts — same as index + contact -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      /* ─── Design tokens — identical to index.astro + contact.astro ─── */
      :root {
        --light-bg: #f0efec;
        --dark-text: #1c2b25;
        --green: #3a7a5a;
        --green-hover: #2e6148;
        --green-faint: rgba(58, 122, 90, 0.08);
        --mauve: #8b3558;
        --mauve-faint: rgba(139, 53, 88, 0.07);
        --muted: #6b7b72;
        --border: #d4d2ce;
        --font: "Nunito", sans-serif;
      }

      html,
      body {
        background-color: var(--light-bg);
        color: var(--dark-text);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.7;
      }

      /* ─── Page layout ─── */
      .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 2fr;
        grid-template-rows: auto 1fr;
      }

      /* ─── Sticky sidebar (left) ─── */
      .sidebar {
        grid-row: 1 / -1;
        background-color: var(--mauve);
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2.5rem;
        gap: 1.5rem;
        text-align: center;
      }

      /* dot texture — same as index/contact right panel */
      .sidebar::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.06) 1px,
          transparent 1px
        );
        background-size: 22px 22px;
      }

      .sidebar-inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
      }

      .avatar-ring {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        border: 4px solid #fff;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        flex-shrink: 0;
      }

      .avatar-ring img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }

      .sidebar-name {
        font-size: 1.4rem;
        font-weight: 900;
        color: #fff;
        line-height: 1.1;
      }

      .sidebar-role {
        font-size: 0.8rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .sidebar-tagline {
        font-size: 0.88rem;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.6;
        max-width: 22ch;
      }

      .sidebar-divider {
        width: 40px;
        height: 2px;
        background: rgba(255, 255, 255, 0.25);
        border-radius: 2px;
      }

      /* ─── Main content (right) ─── */
      .content {
        padding: 4rem 4rem 5rem 4.5rem;
        max-width: 720px;
      }

      /* ─── Section ─── */
      .section {
        margin-bottom: 3.5rem;
      }

      .section-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 0.5rem;
      }

      .section-title {
        font-size: clamp(1.5rem, 2.5vw, 2rem);
        font-weight: 900;
        color: var(--dark-text);
        line-height: 1.15;
        margin-bottom: 1.25rem;
      }

      .section p {
        font-size: 0.95rem;
        font-weight: 400;
        color: var(--dark-text);
        opacity: 0.85;
        margin-bottom: 1rem;
        max-width: 62ch;
      }

      .section p:last-child {
        margin-bottom: 0;
      }

      /* ─── Highlight block ─── */
      .highlight-block {
        background: var(--mauve-faint);
        border-left: 3px solid var(--mauve);
        border-radius: 0 6px 6px 0;
        padding: 1rem 1.25rem;
        margin: 1.5rem 0;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--dark-text);
        opacity: 0.9;
        max-width: 60ch;
      }

      /* ─── Skills grid ─── */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
      }

      .skill-chip {
        background: var(--green-faint);
        border: 1.5px solid rgba(58, 122, 90, 0.2);
        border-radius: 6px;
        padding: 0.5rem 0.875rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--green);
        letter-spacing: 0.02em;
      }

      /* ─── Section divider ─── */
      .section-rule {
        border: none;
        border-top: 1.5px solid var(--border);
        margin: 0 0 3.5rem 0;
      }

      /* ─── Responsive ─── */
      @media (max-width: 900px) {
        .page {
          grid-template-columns: 1fr;
          grid-template-rows: auto auto;
        }

        .sidebar {
          position: static;
          height: auto;
          min-height: 280px;
          padding: 3rem 2rem;
        }

        .avatar-ring {
          width: 120px;
          height: 120px;
        }

        .content {
          padding: 3rem 1.5rem 4rem;
        }
      }
    </style>
  </head>

  <body>
    <!-- <Header /> -->
    <Header />
    <div class="page">
      <!-- Left: sticky sidebar -->
      <aside class="sidebar">
        <div class="sidebar-inner">
          <div class="avatar-ring">
            <img src={headshot} alt="brand-logo" />
          </div>
          <div>
            <p class="sidebar-name">{name}</p>
            <p class="sidebar-role">{role}</p>
          </div>
          <div class="sidebar-divider"></div>
          <p class="sidebar-tagline">{tagline}</p>
          <a class="btn btn-light" href="/contact">Reach Out To Me</a>
        </div>
      </aside>

      <!-- Right: content -->
      <main class="content">
        <!-- Bio -->
        <section class="section">
          <span class="section-label">Who I am</span>
          <h1 class="section-title">A little about me.</h1>
          <div class="highlight-block">
            "Technology should serve humanity — not extract from it. That belief
            shapes every line of code I write."
          </div>
          <p>
            I'm Franco, a full-stack software engineer and community builder
            driven by a simple belief: technology should serve people, not the
            other way around. Every project I take on is shaped by that
            conviction.
          </p>
          <p>
            Currently, I'm completing the <strong
              >i.c.stars Technology, Business &amp; Leadership Program</strong
            > in Kansas City, combining hands-on software development with leadership
            training and real-world client work. My capstone project with <strong
              >Birthday Connections</strong
            > — a non-profit serving underserved children — lets me do what I love
            most: building solutions that directly improve people's lives.
          </p>
        </section>

        <hr class="section-rule" />

        <!-- Background -->
        <section class="section">
          <span class="section-label">Background</span>
          <h2 class="section-title">How I got here.</h2>
          <p>
            Before transitioning into tech, I spent years as a <strong
              >child caregiver and CNA</strong
            > — developing patience, communication skills, and a deep understanding
            of what it means to truly serve others. That experience shapes how I write
            code today. I'm not just building features, I'm building trust.
          </p>
          <p>
            I work primarily with <strong
              >C#, ASP.NET Core, and JavaScript</strong
            >, creating secure, scalable web applications that prioritize the
            user experience. Whether I'm implementing real-time features with
            SignalR or designing intuitive interfaces with Bootstrap, I approach
            every project with both technical rigor and genuine empathy for the
            people who'll use what I build.
          </p>
        </section>

        <hr class="section-rule" />

        <!-- Skills -->
        <section class="section">
          <span class="section-label">Skills</span>
          <h2 class="section-title">What I work with.</h2>
          <div class="skills-grid">
            <div class="skill-chip">C# / ASP.NET Core</div>
            <div class="skill-chip">Java / Spring Boot</div>
            <div class="skill-chip">Python / Django</div>
            <div class="skill-chip">JavaScript</div>
            <div class="skill-chip">Blazor</div>
            <div class="skill-chip">Angular</div>
            <div class="skill-chip">SignalR</div>
            <div class="skill-chip">Bootstrap 5</div>
            <div class="skill-chip">PostgreSQL</div>
            <div class="skill-chip">Docker</div>
            <div class="skill-chip">EF Core</div>
            <div class="skill-chip">Git / GitHub</div>
          </div>
        </section>

        <hr class="section-rule" />

        <!-- Values / Outside work -->
        <section class="section">
          <span class="section-label">Beyond the code</span>
          <h2 class="section-title">What else drives me.</h2>
          <p>
            I'm bilingual in <strong>English and Spanish</strong>, and
            passionate about community outside of work as much as inside it. I
            volunteer with <strong>Urban Station KCK Community Garden</strong>,
            where urban agriculture meets the kind of grassroots community
            building I believe in.
          </p>
          <p>
            I'm always looking to collaborate with organizations that value
            sustainable human growth and environmental responsibility — the kind
            of work where good code and good values point in the same direction.
          </p>
        </section>
      </main>
    </div>

    <Footer />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
