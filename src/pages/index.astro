---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_TITLE}</title>

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --light-bg: #f0efec;
        --dark-text: #1c2b25;
        --green: #3a7a5a;
        --green-hover: #2e6148;
        --mauve: #8b3558;
        --mauve-text: #ffffff;
        --font: "Nunito", sans-serif;
      }

      html,
      body {
        height: 100%;
        font-family: var(--font);
        overflow: hidden; /* full-screen split */
      }

      /* ─── Split layout ─── */
      .split {
        display: flex;
        height: 100vh;
        width: 100vw;
      }

      .panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 4rem;
        transition: flex 0.5s ease;
      }

      /* ─── Left panel ─── */
      .panel--left {
        background-color: var(--light-bg);
        color: var(--dark-text);
      }

      .left-content {
        max-width: 420px;
        text-align: center;
      }

      .greeting {
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
        font-weight: 900;
        letter-spacing: -0.01em;
        line-height: 1.1;
        margin-bottom: 1rem;
        color: var(--dark-text);
      }

      .greeting .name-accent {
        color: var(--green);
      }

      .subtitle {
        font-size: 1rem;
        font-weight: 600;
        color: var(--dark-text);
        margin-bottom: 1.25rem;
        opacity: 0.75;
      }

      .bio {
        font-size: 0.95rem;
        font-weight: 400;
        line-height: 1.7;
        color: var(--dark-text);
        opacity: 0.7;
        margin-bottom: 2rem;
        max-width: 36ch;
        margin-left: auto;
        margin-right: auto;
      }

      .btn-mood {
        background-color: var(--green);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-family: var(--font);
        font-size: 0.9rem;
        font-weight: 700;
        padding: 0.65rem 1.75rem;
        cursor: pointer;
        transition:
          background-color 0.2s ease,
          transform 0.1s ease;
        letter-spacing: 0.01em;
      }

      .btn-mood:hover {
        background-color: var(--green-hover);
      }

      .btn-mood:active {
        transform: translateY(1px);
      }

      /* ─── Right panel ─── */
      .panel--right {
        background-color: var(--mauve);
        color: var(--mauve-text);
      }

      /* subtle dot texture matching screenshot */
      .panel--right::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.06) 1px,
          transparent 1px
        );
        background-size: 22px 22px;
      }

      .right-content {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .avatar-ring {
        width: 220px;
        height: 220px;
        border-radius: 50%;
        border: 5px solid #ffffff;
        overflow: hidden;
        flex-shrink: 0;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      }

      .avatar-ring img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }

      .role-label {
        font-size: clamp(1rem, 2vw, 1.3rem);
        font-weight: 800;
        letter-spacing: 0.01em;
        color: #fff;
        text-align: center;
      }

      /* ─── Mood switcher ─── */
      /* Second mood: inverted — dark left, light right */
      body.mood-2 .panel--left {
        background-color: #1c2b25;
        color: #f0efec;
      }
      body.mood-2 .greeting {
        color: #f0efec;
      }
      body.mood-2 .subtitle {
        color: #f0efec;
      }
      body.mood-2 .bio {
        color: #f0efec;
      }
      body.mood-2 .panel--right {
        background-color: #f0efec;
        color: var(--dark-text);
      }
      body.mood-2 .role-label {
        color: var(--dark-text);
      }
      body.mood-2 .btn-mood {
        background-color: #f0efec;
        color: var(--dark-text);
      }
      body.mood-2 .btn-mood:hover {
        background-color: #dddbd6;
      }

      /* ─── Responsive ─── */
      @media (max-width: 768px) {
        html,
        body {
          overflow: auto;
        }

        .split {
          flex-direction: column;
          height: auto;
          min-height: 100vh;
        }

        .panel {
          padding: 3.5rem 2rem;
        }

        .panel--right {
          min-height: 50vh;
        }

        .avatar-ring {
          width: 180px;
          height: 180px;
        }
      }
    </style>
  </head>

  <body>
    <Header />
	<main class="split">
		<!-- Left: text content -->
      <div class="panel panel--left">
        <div class="left-content">
			<img src="/src/assets/fahrdesigns-logo.png" alt="brand-logo" width="420px;"/>

          <h1 class="greeting">
            FAHR <span class="name-accent">DESIGNS</span>
          </h1>
          <p class="subtitle">Tools for communities. Code with conscience.</p>
		  
          <!-- <p class="bio"></p> -->
		   <a class="btn btn-light" href="/about">Learn More</a>
          <button class="btn-mood" id="moodBtn">Switch Mood</button>

        </div>
      </div>

      <!-- Right: photo + role -->
      <!-- <div class="panel panel--right position-relative">
        <div class="right-content">
          <div class="avatar-ring">
            <img src="/src/assets/playful-headshot.webp" alt="brand-logo" />
          </div>
          <p class="role-label">Full-stack developer. Former nurse. Building tools that actually help people.</p>
        </div>
      </div> -->
	</main>

	<Footer />

    <!-- Bootstrap 5 JS (optional — only needed if you use BS components) -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      defer></script>

    <script>
      const btn = document.getElementById("moodBtn");
      let mood = 1;

      btn?.addEventListener("click", () => {
        mood = mood === 1 ? 2 : 1;
        document.body.classList.toggle("mood-2", mood === 2);
      });
    </script>
  </body>

</html>
